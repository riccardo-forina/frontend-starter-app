{
  "name": "frontend-starter-app",
  "version": "1.2.0",
  "private": false,
  "engines": {
    "node": ">=18.20.8",
    "npm": ">=8.19.4"
  },
  "scripts": {
    "build": "fec build",
    "deploy": "npm-run-all build lint test",
    "lint": "npm-run-all lint:*",
    "lint:js": "eslint src",
    "lint:js:fix": "eslint src --fix",
    "patch:hosts": "fec patch-etc-hosts",
    "start": "HOT=true fec dev",
    "static": "fec static",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "jest",
    "test:cypress": "cypress run --component",
    "test:cypress:open": "cypress open --component",
    "test:cypress:component": "cypress run --component",
    "postinstall": "ts-patch install && rimraf .cache",
    "verify": "npm-run-all build lint test"
  },
  "dependencies": {
    "@patternfly/react-core": "^6.4.3",
    "@patternfly/react-data-view": "^6.4.0",
    "@patternfly/react-table": "^6.4.3",
    "@redhat-cloud-services/frontend-components": "^7.4.2",
    "@redhat-cloud-services/frontend-components-notifications": "^6.6.2",
    "@redhat-cloud-services/frontend-components-utilities": "^7.3.1",
    "@scalprum/core": "^0.9.0",
    "@scalprum/react-core": "^0.11.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3"
  },
  "devDependencies": {
    "@cypress/code-coverage": "^3.14.7",
    "@cypress/react": "^9.0.2",
    "@playwright/test": "^1.59.1",
    "@redhat-cloud-services/eslint-config-redhat-cloud-services": "^3.1.1",
    "@redhat-cloud-services/frontend-components-config": "^6.10.0",
    "@redhat-cloud-services/playwright-test-auth": "^0.0.2",
    "@redhat-cloud-services/tsc-transform-imports": "^1.1.1",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-webpack5-compiler-swc": "^4.0.3",
    "@storybook/react-webpack5": "^10.3.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@types/jest": "^29.5.14",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/parser": "^8.59.2",
    "cypress": "^15.14.2",
    "identity-obj-proxy": "^3.0.0",
    "jest-environment-jsdom": "^29.7.0",
    "msw": "^2.14.6",
    "msw-storybook-addon": "^2.0.7",
    "npm-run-all2": "^5.0.2",
    "rimraf": "^5.0.10",
    "storybook": "^10.3.6",
    "ts-jest": "^29.4.9",
    "ts-patch": "^3.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "webpack-bundle-analyzer": "4.10.2"
  },
  "insights": {
    "appname": "frontend-starter-app"
  },
  "msw": {
    "workerDirectory": [
      "static"
    ]
  }
}